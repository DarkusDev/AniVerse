generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnimeStatus {
  WATCHING
  COMPLETED
  PLANNED
  DROPPED
  PAUSED
}

model User {
  id               String       @id @default(uuid()) @db.Uuid
  email            String       @unique
  username         String       @unique
  passwordHash     String
  refreshTokenHash String?
  avatarUrl        String?
  bio              String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  animeList        AnimeList[]
  customLists      CustomList[]

  @@map("users")
}

model AnimeCache {
  animeId      Int      @id
  titleRomaji  String?
  titleEnglish String?
  coverImage   String?
  format       String?
  episodes     Int?
  status       String?
  season       String?
  seasonYear   Int?
  genres       String[]
  averageScore Int?
  cachedAt     DateTime @updatedAt

  animeList         AnimeList[]
  customListEntries CustomListEntry[]

  @@map("anime_cache")
}

model AnimeList {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @db.Uuid
  animeId          Int
  status           AnimeStatus
  score            Decimal?    @db.Decimal(4, 1)
  episodesWatched  Int         @default(0)
  totalEpisodes    Int?
  startDate        DateTime?   @db.Date
  finishDate       DateTime?   @db.Date
  notes            String?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeCache       AnimeCache  @relation(fields: [animeId], references: [animeId])

  @@unique([userId, animeId])
  @@index([userId, status])
  @@map("anime_list")
}

model CustomList {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @db.Uuid
  name        String            @db.VarChar(100)
  description String?           @db.VarChar(500)
  isPublic    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     CustomListEntry[]

  @@index([userId])
  @@map("custom_lists")
}

model CustomListEntry {
  customListId String     @db.Uuid
  animeId      Int
  addedAt      DateTime   @default(now())

  customList   CustomList @relation(fields: [customListId], references: [id], onDelete: Cascade)
  animeCache   AnimeCache @relation(fields: [animeId], references: [animeId])

  @@id([customListId, animeId])
  @@map("custom_list_entries")
}
